{
  "name": "ambient-bgm-api",
  "version": "0.1.0",
  "description": "Ambient Background Music Generator API (Fastify, TypeScript, Supabase, OpenAI)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/formbody": "^7.4.0",
    "@supabase/supabase-js": "^2.47.5",
    "dotenv": "^17.2.3",
    "fastify": "^4.28.1",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": "21.4.0",
    "pnpm": "10.23.0"
  }
}
